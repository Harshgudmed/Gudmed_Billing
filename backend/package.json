{
  "name": "hospital-backend",
  "version": "1.0.0",
  "description": "Hospital Management System - Express MVC Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:erd": "node prisma/generate-erd.mjs",
    "test:integration": "node --test --test-force-exit src/integration/__tests__/hl7Parser.test.js src/integration/__tests__/listener.test.js",
    "test:unit": "node --test --test-force-exit src/lib/__tests__/*.test.js",
    "hl7:simulate": "node scripts/hl7-simulator.js",
    "hl7:inject": "node scripts/hl7-inject.js"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "razorpay": "^2.9.6",
    "simple-hl7": "^3.3.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.11.1",
    "prisma-erd-generator": "^2.4.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
