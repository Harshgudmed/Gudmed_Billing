// Hospital Management System - Complete Database Schema
// PostgreSQL with comprehensive hospital management features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE TABLES
// ============================================

/// Hospital/Organization
model Organization {
  id             String  @id @default(cuid())
  name           String
  slug           String  @unique
  logoUrl        String?
  primaryColor   String  @default("#2563eb")
  secondaryColor String  @default("#7c3aed")

  // Contact Info
  email   String?
  phone   String?
  address String?
  city    String?
  region  String?
  country String  @default("Ethiopia")

  // Settings (JSON string)
  settings String @default("{\"currency\":\"INR\",\"language\":\"en\",\"timezone\":\"Asia/Kolkata\",\"workingHours\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"appointmentDuration\":30}")

  // Subscription
  subscriptionTier      String    @default("basic")
  subscriptionStatus    String    @default("trial")
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?

  // Modules enabled (JSON string)
  modulesEnabled String @default("{\"pharmacy\":true,\"laboratory\":true,\"radiology\":true,\"inpatient\":false,\"inventory\":true,\"accounting\":false}")

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  // Relations
  users               User[]
  patients            Patient[]
  appointments        Appointment[]
  consultations       Consultation[]
  pharmacyDrugs       PharmacyDrug[]
  prescriptions       Prescription[]
  pharmacySales       PharmacySale[]
  labTests            LabTest[]
  labOrders           LabOrder[]
  radiologyExams      RadiologyExam[]
  radiologyOrders     RadiologyOrder[]
  billingServices     BillingService[]
  invoices            Invoice[]
  payments            Payment[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  userInvitations     UserInvitation[]
  departments         Department[]
  wards               Ward[]
  beds                Bed[]
  admissions          Admission[]
  doctorFeeSlabs           DoctorFeeSlab[]
  doctorCommissionConfigs  DoctorCommissionConfig[]
  doctorCommissions        DoctorCommission[]
  pharmacyPurchaseOrders   PharmacyPurchaseOrder[]
  vendors                  Vendor[]
  machineIntegrations MachineIntegration[]
  machineResultsQueue MachineResultsQueue[]

  // eAPTS Relations
  eaptsConfig             EaptsConfig?
  eaptsMedicationMappings EaptsMedicationMapping[]
  eaptsTransactions       EaptsTransaction[]
  patientDocuments        PatientDocument[]

  // Enterprise IPD Relations
  bedCategories  BedCategory[]
  tariffPlans    TariffPlan[]
  tariffRules    TariffRule[]
  chargeMasters  ChargeMaster[]
  patientTariffs PatientTariff[]
  bedOccupancies BedOccupancy[]
  ipdCharges     IpdCharge[]
  vitalsRecords  VitalsRecord[]
  clinicalNotesV2 ClinicalNote[]
  medicationAdministrations MedicationAdministration[]
  dischargeClearances DischargeClearance[]
  housekeepingTasks   HousekeepingTask[]
  bills               Bill[]
  billCounters        BillCounter[]
  billPayments        BillPayment[]
  clinicalOrders      ClinicalOrder[]
  orderTasks          OrderTask[]

  ipdConsultations    IpdConsultation[]
}

/// User (Staff)
model User {
  id             String  @id @default(cuid())
  organizationId String
  email          String  @unique
  passwordHash   String?

  // Personal Info
  fullName    String
  phone       String?
  dateOfBirth DateTime?
  gender      String?
  address     String?

  // Professional Info
  employeeId     String?
  role           String // super_admin, admin, doctor, nurse, receptionist, pharmacist, lab_tech, lab_supervisor, radiologist, radiology_tech, billing_clerk, inventory_manager
  departmentId   String?
  specialization String?
  licenseNumber  String?
  consultationFee Float?  // default appointment/consultation fee for this doctor (₹)
  followUpDays    Int?    // free follow-up window: a repeat visit to this doctor within N days is not charged

  // System
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  preferences     String? // JSON string for UI preferences
  defaultCalendar String    @default("ethiopian") // 'ethiopian' or 'gregorian'
  
  // Invitation System
  invitationToken     String?   @unique
  invitationExpiresAt DateTime?
  invitedById         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  // Relations
  organization               Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department                 Department?        @relation(fields: [departmentId], references: [id])
  appointmentsAsDoctor       Appointment[]      @relation("DoctorAppointments")
  consultations              Consultation[]     @relation("DoctorConsultations")
  prescriptions              Prescription[]     @relation("PrescribingDoctor")
  prescriptionsDispensed     Prescription[]     @relation("DispensingPharmacist")
  pharmacySales              PharmacySale[]     @relation("PharmacySalesBy")
  labOrdersRequested         LabOrder[]         @relation("LabOrdersRequested")
  labOrdersCollected         LabOrder[]         @relation("LabOrdersCollected")
  labResultsEntered          LabResult[]        @relation("LabResultsEntered")
  labResultsVerified         LabResult[]        @relation("LabResultsVerified")
  radiologyOrdersRequested   RadiologyOrder[]   @relation("RadiologyOrdersRequested")
  radiologyOrdersPerformed   RadiologyOrder[]   @relation("RadiologyOrdersPerformed")
  radiologyReports           RadiologyReport[]  @relation("RadiologyReports")
  invoicesCreated            Invoice[]          @relation("InvoicesCreated")
  invoicesCancelled          Invoice[]          @relation("InvoicesCancelled")
  paymentsProcessed          Payment[]          @relation("PaymentsProcessed")
  auditLogs                  AuditLog[]         @relation("AuditLogsByUser")
  notifications              Notification[]     @relation("UserNotifications")
  checkedInAppointments      Appointment[]      @relation("CheckedInBy")

  // User Management Relations
  invitedBy              User?             @relation("UserInvitations", fields: [invitedById], references: [id])
  invitedUsers           User[]            @relation("UserInvitations")
  userInvitations        UserInvitation[]  @relation("InvitationsSent")
  userActivities         UserActivity[]

  // Doctor Accountability
  feeSlabs               DoctorFeeSlab[]         @relation("DoctorFeeSlabs")
  commissionConfig       DoctorCommissionConfig? @relation("DoctorCommissionConfig")
  commissions            DoctorCommission[]      @relation("DoctorCommissions")
  commissionsSettled     DoctorCommission[]      @relation("CommissionsSettled")

  // IPD Specialist Consultations
  ipdConsultationsAsDoctor  IpdConsultation[] @relation("ConsultingDoctorIPD")
  ipdConsultationsRequested IpdConsultation[] @relation("ConsultationRequestedBy")

  // IPD admissions where this user is the attending / admitting / discharge doctor
  attendingAdmissions Admission[] @relation("AttendingDoctor")
  admittingAdmissions Admission[] @relation("AdmittingDoctor")
  dischargeAdmissions Admission[] @relation("DischargeDoctor")

  @@index([organizationId])
  @@index([role])
  @@index([isActive])
  @@index([invitationToken])
}

/// Department
model Department {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String?
  description    String?
  headId         String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users            User[]
  wards            Ward[]
  ipdConsultations IpdConsultation[]

  // One department name per organization — prevents the duplicate-department
  // rows that the frontend used to compensate for.
  @@unique([organizationId, name])
  @@index([organizationId])
}

/// Patient
model Patient {
  id             String @id @default(cuid())
  organizationId String

  // Identification
  mrn        String  @unique // Medical Record Number
  externalId String?

  // Patient-portal login (optional — set when the patient is given portal access)
  passwordHash String?

  // Personal Information
  firstName   String
  middleName  String?
  lastName    String
  dateOfBirth DateTime
  gender      String // male, female, other
  bloodGroup  String? // A+, B+, O+, AB+, A-, B-, O-, AB-

  // Contact
  phonePrimary   String?
  phoneSecondary String?
  email          String?

  // Address (Ethiopian format)
  region             String?
  zone               String?
  woreda             String?
  kebele             String?
  houseNumber        String?
  postalCode         String? // PIN code
  addressDescription String? // legacy free-text address — kept so existing data isn't dropped

  // Emergency Contact
  emergencyContactName         String?
  emergencyContactPhone        String?
  emergencyContactRelationship String?

  // Medical Information (JSON arrays as strings)
  allergies          String? // JSON array
  chronicConditions  String? // JSON array
  currentMedications String? // JSON array

  // Insurance
  hasInsurance             Boolean   @default(false)
  insuranceProvider        String?
  insuranceId              String?
  insuranceExpiryDate      DateTime?
  insuranceCoverageDetails String? // JSON

  // Additional
  photoUrl       String?
  maritalStatus  String?
  referredBy     String? // who referred the patient (doctor, clinic, person)
  mlcNumber      String? // Medico-Legal Case number (police case / accident registrations)
  occupation     String?
  educationLevel String?

  // System
  isActive Boolean @default(true)
  isVip    Boolean @default(false)
  notes    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  // Relations
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  consultations       Consultation[]
  prescriptions       Prescription[]
  pharmacySales       PharmacySale[]
  labOrders           LabOrder[]
  radiologyOrders     RadiologyOrder[]
  invoices            Invoice[]
  payments            Payment[]
  admissions          Admission[]
  machineResultsQueue MachineResultsQueue[]
  patientDocuments    PatientDocument[]

  @@index([organizationId])
  @@index([mrn])
  @@index([lastName, firstName])
  @@index([phonePrimary])
}

/// Patient Document (KYC & Records)
model PatientDocument {
  id             String   @id @default(cuid())
  organizationId String
  patientId      String

  documentType   String   // aadhaar, pan, insurance, referral, lab_report, prescription, history, other
  title          String?
  fileUrl        String
  fileType       String?  // mime type
  uploadedAt     DateTime @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([patientId])
}

/// Appointment
model Appointment {
  id             String @id @default(cuid())
  organizationId String

  // Relations
  patientId String
  doctorId  String?

  // Appointment Details
  appointmentDate DateTime
  appointmentTime String
  appointmentType String? // new_patient, follow_up, emergency
  departmentId    String?
  priority        String  @default("normal") // normal, urgent
  consultationFee Float?  // fee charged for this appointment (₹)

  // Status
  status String @default("scheduled") // scheduled, confirmed, checked_in, in_progress, completed, cancelled, no_show, rescheduled

  // Clinical
  chiefComplaint    String?
  notes             String?
  consultationNotes String?

  // Check-in/Check-out
  checkedInAt   DateTime?
  checkedInById String?
  startedAt     DateTime?
  completedAt   DateTime?

  // Cancellation
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?

  // Rescheduling (IDs only, no relations to avoid circular dependency)
  rescheduledFromId String?
  rescheduledToId   String?

  // Reminders
  reminderSent   Boolean   @default(false)
  reminderSentAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        User?          @relation("DoctorAppointments", fields: [doctorId], references: [id])
  checkedInBy   User?          @relation("CheckedInBy", fields: [checkedInById], references: [id])
  consultations Consultation[]

  @@index([organizationId])
  @@index([patientId])
  @@index([doctorId])
  @@index([organizationId, appointmentDate])
  @@index([organizationId, appointmentDate, doctorId])
  @@index([organizationId, appointmentDate, status])
  @@index([appointmentDate, appointmentTime])
  @@index([status])
}

/// Consultation (Visit Record)
model Consultation {
  id             String @id @default(cuid())
  organizationId String

  // Relations
  patientId     String
  appointmentId String?
  doctorId      String

  // Visit Info
  visitDate DateTime @default(now())
  visitType String? // outpatient, emergency, follow_up

  // Vitals
  temperature            Float?
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  pulseRate              Int?
  respiratoryRate        Int?
  weight                 Float?
  height                 Float?
  oxygenSaturation       Int?

  // Clinical Notes
  chiefComplaint          String?
  historyOfPresentIllness String?
  physicalExamination     String?
  diagnosis               String?
  icd10Codes              String? // JSON array

  // Treatment Plan
  treatmentPlan        String?
  followUpInstructions String?
  followUpDate         DateTime?

  // Referrals
  referredTo     String?
  referralReason String?

  // Additional
  notes       String?
  attachments String? // JSON array of file URLs

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  // Relations
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient         Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment     Appointment?     @relation(fields: [appointmentId], references: [id])
  doctor          User             @relation("DoctorConsultations", fields: [doctorId], references: [id])
  prescriptions   Prescription[]
  labOrders       LabOrder[]
  radiologyOrders RadiologyOrder[]
  invoices        Invoice[]

  @@index([organizationId])
  @@index([patientId])
  @@index([doctorId])
  @@index([visitDate])
}

// ============================================
// INPATIENT MODULE
// ============================================

/// Ward
model Ward {
  id             String   @id @default(cuid())
  organizationId String
  departmentId   String?
  name           String
  code           String?
  type           String? // general, icu, nicu, pediatric, maternity
  capacity       Int      @default(0)
  building       String? // multi-building hospitals (e.g. "A Block", "Main Building")
  floor          String?
  chargeNurse    String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id])
  beds         Bed[]

  @@index([organizationId])
}

/// Bed
model Bed {
  id               String   @id @default(cuid())
  organizationId   String
  wardId           String
  bedCategoryId    String? // pricing tier (General, Private, ICU…) — drives the tariff engine
  bedNumber        String
  type             String? // standard, icu, special
  status           String   @default("available") // available, occupied, maintenance, reserved, dirty, cleaning
  currentPatientId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ward         Ward               @relation(fields: [wardId], references: [id], onDelete: Cascade)
  bedCategory  BedCategory?       @relation(fields: [bedCategoryId], references: [id])
  admissions   Admission[]
  occupancies  BedOccupancy[]
  housekeepingTasks HousekeepingTask[]

  @@index([organizationId])
  @@index([wardId])
  @@index([status])
}

/// Admission
model Admission {
  id             String  @id @default(cuid())
  organizationId String
  patientId      String
  bedId          String?

  admissionDate        DateTime @default(now())
  admissionType        String? // emergency, elective, transfer
  admissionReason      String?
  admissionDiagnosis   String?
  chiefComplaint       String?
  expectedLengthOfStay Int?
  depositAmount        Float?
  admissionNotes       String?
  isCritical           Boolean  @default(false)
  criticalLevel        String?  // 'blue' or 'yellow'
  admittingDoctorId    String?
  attendingDoctorId    String?

  // Status
  status String @default("admitted") // admitted, discharged, transferred (kept for backward compat)

  // Enterprise state machine (Phase 3) — richer lifecycle alongside `status`
  admissionState String? // REQUESTED|BED_RESERVED|ADMITTED|IN_TREATMENT|DISCHARGE_INITIATED|CLEARANCES_PENDING|BILL_FINALIZED|DISCHARGED|LAMA|ABSCONDED|EXPIRED|TRANSFERRED_OUT
  dischargeType  String? // NORMAL|LAMA|ABSCONDED|EXPIRED|TRANSFER_OUT

  // Discharge
  dischargeDate          DateTime?
  dischargeReason        String?
  dischargeDiagnosis     String?
  dischargeSummary       String?
  treatmentSummary       String?
  dischargeCondition     String?
  medicationsOnDischarge String?
  dischargeNotes         String?
  followUpInstructions   String?
  dischargeDoctorId      String?

  // Follow-up
  followUpDate  DateTime?
  followUpNotes String?

  // Clinical notes (JSON: [{id, date, noteType, note, authorName, vitals?}])
  clinicalNotes String?

  // IPD billing snapshot
  dailyRoomRate     Float?
  totalBillAmount   Float?
  billGenerated     Boolean @default(false)
  additionalCharges String? // JSON: [{id, name, type, amount, quantity, date}]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id])
  bed          Bed?         @relation(fields: [bedId], references: [id])

  // Doctor relations — were bare IDs (needed a manual name lookup); the relation
  // lets Prisma resolve doctor names directly via `include`. Optional (no FK on delete).
  attendingDoctor User? @relation("AttendingDoctor", fields: [attendingDoctorId], references: [id])
  admittingDoctor User? @relation("AdmittingDoctor", fields: [admittingDoctorId], references: [id])
  dischargeDoctor User? @relation("DischargeDoctor", fields: [dischargeDoctorId], references: [id])

  // Enterprise IPD children (FK-enforced; cascade on admission delete)
  occupancies               BedOccupancy[]
  ipdCharges                IpdCharge[]
  vitalsRecords             VitalsRecord[]
  clinicalNotesV2           ClinicalNote[]
  medicationAdministrations MedicationAdministration[]
  dischargeClearances       DischargeClearance[]
  patientTariff             PatientTariff?
  bills                     Bill[]
  billPayments              BillPayment[]
  clinicalOrders            ClinicalOrder[]
  ipdConsultations          IpdConsultation[]
  orderTasks                OrderTask[]

  @@index([organizationId])
  @@index([patientId])
  @@index([status])
}

// ============================================
// PHARMACY MODULE
// ============================================

/// Pharmacy Drug (Drug Catalog/Inventory)
model PharmacyDrug {
  id             String @id @default(cuid())
  organizationId String

  // Drug Information
  drugName     String
  genericName  String?
  brandName    String?
  drugCode     String?
  drugCategory String? // antibiotic, analgesic, etc.
  dosageForm   String? // tablet, capsule, syrup, injection
  strength     String? // 500mg, 10mg/ml, etc.

  // Inventory
  quantityInStock   Int     @default(0)
  unitOfMeasure     String? // tablet, bottle, vial, box
  reorderLevel      Int     @default(10)
  maximumStockLevel Int?

  // Pricing
  costPrice        Float?
  sellingPrice     Float?
  markupPercentage Float?
  purchasePrice    Float? // explicit purchase price (costPrice kept for back-compat)
  mrp              Float? // printed maximum retail price
  gstRate          Float? // GST percentage
  hsnCode          String?

  // Identification
  barcode      String? // EAN-13 / UPC / Code128 / QR payload scanned at the counter
  manufacturer String? // distinct from the free-text supplierName below

  // Storage
  storageLocation      String?
  requiresPrescription Boolean @default(false)

  // Supplier
  supplierName    String?
  supplierContact String?

  // Additional
  description       String?
  sideEffects       String?
  contraindications String?
  isActive          Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  organization  Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  batches       PharmacyBatch[]
  stockLedger   StockLedger[]
  eaptsMappings EaptsMedicationMapping[]

  // Barcode uniqueness is enforced in the controller (see drug.controller.create/update),
  // not via a DB unique constraint — a unique constraint makes `prisma db push` demand
  // --accept-data-loss, which would break the Render deploy pipeline.
  @@index([organizationId])
  @@index([drugName])
  @@index([drugCategory])
  @@index([quantityInStock])
  @@index([barcode])
}

/// Pharmacy Batch (Batch/Lot Tracking)
model PharmacyBatch {
  id             String @id @default(cuid())
  organizationId String
  drugId         String

  // Batch Info
  batchNumber     String
  manufactureDate DateTime?
  expiryDate      DateTime

  // Quantity
  quantityReceived  Int
  quantityRemaining Int

  // Purchase
  purchaseOrderNumber String?
  purchaseDate        DateTime?
  costPricePerUnit    Float?
  totalCost           Float?

  // Supplier
  supplierName    String?
  supplierInvoice String?
  vendorId        String? // optional link to Vendor; free-text supplier fields kept for back-compat

  // Status
  status String @default("active") // active, expired, recalled, depleted

  createdAt   DateTime @default(now())
  createdById String?

  drug   PharmacyDrug @relation(fields: [drugId], references: [id], onDelete: Cascade)
  vendor Vendor?      @relation(fields: [vendorId], references: [id])

  @@index([drugId])
  @@index([expiryDate])
  @@index([status])
  @@index([vendorId])
}

/// Prescription
model Prescription {
  id             String @id @default(cuid())
  organizationId String

  // Relations
  patientId      String
  consultationId String?
  doctorId       String

  // Prescription Details
  prescriptionDate DateTime @default(now())

  // Items (JSON array)
  items String // JSON: [{drugId, drugName, dosage, frequency, duration, quantity, instructions}]

  // Dispensing
  status        String    @default("pending") // pending, partially_dispensed, fully_dispensed, cancelled
  dispensedById String?
  dispensedAt   DateTime?

  // Additional
  notes            String?
  isRefill         Boolean @default(false)
  refillsAllowed   Int     @default(0)
  refillsRemaining Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultation  Consultation?  @relation(fields: [consultationId], references: [id])
  doctor        User           @relation("PrescribingDoctor", fields: [doctorId], references: [id])
  dispensedBy   User?          @relation("DispensingPharmacist", fields: [dispensedById], references: [id])
  pharmacySales PharmacySale[]

  @@index([organizationId])
  @@index([patientId])
  @@index([status])
}

/// Pharmacy Sale
model PharmacySale {
  id             String @id @default(cuid())
  organizationId String

  // Relations
  patientId      String?
  prescriptionId String?
  servedById     String?

  // Sale Details
  saleDate DateTime @default(now())
  saleType String? // prescription, otc

  // Items (JSON array)
  items String // JSON: [{drugId, batchId, drugName, quantity, unitPrice, total}]

  // Financial
  subtotal       Float
  discountAmount Float @default(0)
  taxAmount      Float @default(0)
  totalAmount    Float

  // Payment
  paymentStatus String  @default("pending") // pending, paid, partially_paid
  paymentMethod String?
  amountPaid    Float   @default(0)
  amountDue     Float?

  // Receipt
  receiptNumber String @unique

  createdAt   DateTime @default(now())
  createdById String?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient?      @relation(fields: [patientId], references: [id])
  prescription Prescription? @relation(fields: [prescriptionId], references: [id])
  servedBy     User?         @relation("PharmacySalesBy", fields: [servedById], references: [id])

  @@index([organizationId])
  @@index([patientId])
  @@index([saleDate])
}

/// Pharmacy Purchase Order
model PharmacyPurchaseOrder {
  id             String @id @default(cuid())
  organizationId String

  poNumber String // e.g. PO-2026-0001
  status   String @default("draft") // draft | submitted | approved | received | cancelled

  // Supplier
  supplierName    String
  supplierContact String?
  supplierEmail   String?
  vendorId        String? // optional link to Vendor; free-text supplier fields kept for back-compat

  // Dates
  orderDate            DateTime  @default(now())
  expectedDeliveryDate DateTime?
  receivedDate         DateTime?

  // Items (JSON): [{drugId, drugName, strength, quantityOrdered, quantityReceived, unitCost, totalCost, batchNumber, expiryDate}]
  items       String
  totalAmount Float  @default(0)

  notes            String?
  cancellationNote String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([orderDate])
  @@index([vendorId])
}

/// Stock Ledger — append-only record of every inventory movement (audit + FIFO source of truth)
model StockLedger {
  id             String @id @default(cuid())
  organizationId String

  drugId  String
  batchId String?

  // purchase | sale | dispense | return | adjustment | recall | import
  changeType   String
  quantityDelta Int    // signed: positive = stock in, negative = stock out
  balanceAfter  Int    // drug.quantityInStock after this movement

  reference String? // sale/prescription/PO id or invoice no.
  note      String?

  createdById String?
  createdAt   DateTime @default(now())

  drug PharmacyDrug @relation(fields: [drugId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([drugId])
  @@index([createdAt])
}

/// Vendor / Supplier master
model Vendor {
  id             String @id @default(cuid())
  organizationId String

  name          String
  contactPerson String?
  phone         String?
  email         String?
  gstNumber     String?
  address       String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  batches        PharmacyBatch[]
  purchaseOrders PharmacyPurchaseOrder[]

  @@index([organizationId])
}

/// Reference catalog of Indian medicines (open dataset, ~215k rows) used for
/// name autocomplete when adding a medicine. Global/shared (no organizationId).
/// Populated by scripts/seed-medicine-reference.mjs. Not part of live inventory.
model MedicineReference {
  id             String  @id @default(cuid())
  name           String
  nameLower      String  // lowercased for case-insensitive prefix search
  price          Float?
  manufacturer   String?
  type           String?
  packSize       String?
  composition    String? // combined salt composition (genericName source)
  isDiscontinued Boolean @default(false)

  @@index([nameLower])
  @@index([name])
}

