/// eAPTS Configuration
model EaptsConfig {
  id             String @id @default(cuid())
  organizationId String @unique

  // API Configuration
  apiUrl       String // eAPTS API endpoint
  apiKey       String // Encrypted API key
  facilityCode String // Facility ID in eAPTS system

  // Sync Settings
  isEnabled           Boolean @default(false)
  autoSyncEnabled     Boolean @default(true)
  syncIntervalMinutes Int     @default(60)

  // Sync Status
  lastSyncAt DateTime?
  syncStatus String? // success, failed, in_progress
  syncErrors String? // JSON array of error messages

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

/// eAPTS Medication Mapping
model EaptsMedicationMapping {
  id             String @id @default(cuid())
  organizationId String

  // Local Drug Reference
  localDrugId String

  // eAPTS Drug Information
  eaptsDrugCode      String
  eaptsDrugName      String
  eaptsUnitOfMeasure String?

  // Mapping Status
  mappingStatus String    @default("mapped") // mapped, unmapped, conflict
  lastSyncedAt  DateTime?

  // Metadata
  mappingNotes String? // For manual mapping notes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  drug         PharmacyDrug @relation(fields: [localDrugId], references: [id], onDelete: Cascade)

  @@unique([organizationId, localDrugId])
  @@unique([organizationId, eaptsDrugCode])
  @@index([organizationId])
  @@index([mappingStatus])
}

/// eAPTS Transaction Log
model EaptsTransaction {
  id             String @id @default(cuid())
  organizationId String

  // Transaction Details
  transactionType String // medication_list_sync, prescription_send, dispensing_report, stock_update
  transactionDate DateTime @default(now())

  // Request/Response
  requestPayload  String? // JSON
  responsePayload String? // JSON

  // Status
  status       String  @default("pending") // pending, success, failed
  errorMessage String?
  retryCount   Int     @default(0)

  // Related Entity
  entityType String? // prescription, drug, dispensing
  entityId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([transactionType])
  @@index([status])
  @@index([transactionDate])
}

// ════════════════════════════════════════════════════════════════════════════
// ENTERPRISE IPD — Tariff engine, occupancy ledger, structured charges
// Additive to the existing Ward/Bed/Admission models. See IPD_ENTERPRISE_BLUEPRINT.md
// ════════════════════════════════════════════════════════════════════════════

/// Bed pricing tier (General, Semi-Private, Private, Deluxe, Suite, ICU, HDU, NICU, PICU, Isolation, Burns, VIP)
model BedCategory {
  id                String   @id @default(cuid())
  organizationId    String
  name              String
  code              String
  rank              Int      @default(0) // ordering / escalation level
  defaultBedDayRate Float? // fallback bed/day rate if no tariff rule matches
  isCritical        Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  beds         Bed[]
  occupancies  BedOccupancy[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

/// A named rate card for a payer (Cash 2026, Star Health TPA, CGHS, Corporate…)
model TariffPlan {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  payerType      String // CASH | INSURANCE | TPA | CORPORATE | GOVT | EMPLOYEE
  validFrom      DateTime  @default(now())
  validTo        DateTime?
  isDefault      Boolean   @default(false)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rules        TariffRule[]

  @@index([organizationId])
}

/// Single source of truth for every billable item (bed-day, nursing, doctor visit, procedure, lab, etc.)
model ChargeMaster {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  serviceGroup   String // BED | NURSING | DOCTOR_VISIT | PROCEDURE | LAB | RADIOLOGY | PHARMACY | CONSUMABLE | OTHER
  uom            String? // per-day, per-unit, per-test
  basePrice      Float
  taxRatePct     Float    @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ipdCharges   IpdCharge[]

  @@unique([organizationId, code])
  @@index([organizationId, serviceGroup])
}

/// Configurable adjustment — NO hardcoded percentages. Most-specific rule wins.
model TariffRule {
  id             String    @id @default(cuid())
  organizationId String
  planId         String
  bedCategoryId  String? // null = any category
  serviceGroup   String? // null = any group
  serviceItemId  String? // null = whole group; set = item-specific (wins)
  adjustmentType String // PERCENT | FIXED_DELTA | ABSOLUTE_OVERRIDE
  adjustmentValue Float
  validFrom      DateTime  @default(now())
  validTo        DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         TariffPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([organizationId, planId, bedCategoryId, serviceGroup])
}

/// The tariff plan locked to one admission (snapshot — protects against mid-stay catalog changes)
model PatientTariff {
  id                String   @id @default(cuid())
  organizationId    String
  admissionId       String   @unique
  planId            String
  payerType         String
  corporateId       String?
  insurancePolicyId String?
  lockedAt          DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission    Admission    @relation(fields: [admissionId], references: [id], onDelete: Restrict)

  @@index([organizationId])
}

/// Occupancy-segment ledger — each (admission, bed, category) stay window. Replaces single-bed billing.
model BedOccupancy {
  id             String    @id @default(cuid())
  organizationId String
  admissionId    String
  bedId          String
  bedCategoryId  String? // snapshot the category at time of occupancy
  startAt        DateTime  @default(now())
  endAt          DateTime? // null = current segment
  reason         String? // ADMIT | TRANSFER | ESCALATION | DE_ESCALATION

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission    Admission    @relation(fields: [admissionId], references: [id], onDelete: Restrict)
  bed          Bed          @relation(fields: [bedId], references: [id])
  bedCategory  BedCategory? @relation(fields: [bedCategoryId], references: [id])

  @@index([organizationId, admissionId])
  @@index([bedId, startAt])
}

/// IPD charge line — structured row (replaces JSON charge blobs). Idempotent per source.
model IpdCharge {
  id             String   @id @default(cuid())
  organizationId String
  admissionId    String
  chargeItemId   String? // FK ChargeMaster (null for ad-hoc)
  description    String
  serviceGroup   String
  unitPrice      Float
  quantity       Float    @default(1)
  resolvedFrom   Json? // {planId, bedCategoryId, ruleId} for audit
  serviceDate    DateTime @default(now())
  sourceModule   String? // LAB | RADIOLOGY | PHARMACY | IPD | PROCEDURE
  sourceRef      String? // id in that module (idempotency)
  createdAt      DateTime @default(now())

  // ── Phase 1 billing: snapshot integrity (frozen at post time) ──
  taxPct         Float   @default(0)
  taxAmount      Float   @default(0)
  discountPct    Float   @default(0)
  discountAmount Float   @default(0)
  lineTotal      Float   @default(0) // frozen: unitPrice*qty - discountAmount + taxAmount
  // ── traceability ──
  postedById     String?
  postedByName   String?
  // ── lifecycle (audit-safe cancellation; no hard delete) ──
  status         String    @default("ACTIVE") // ACTIVE | CANCELLED | RETURNED
  cancelReason   String?
  cancelledById  String?
  cancelledAt    DateTime?
  // ── bill linkage ──
  billId         String?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission    Admission     @relation(fields: [admissionId], references: [id], onDelete: Restrict)
  chargeItem   ChargeMaster? @relation(fields: [chargeItemId], references: [id])
  bill         Bill?         @relation(fields: [billId], references: [id], onDelete: SetNull)
  consultation IpdConsultation?

  @@unique([organizationId, sourceModule, sourceRef])
  @@index([organizationId, admissionId])
  @@index([billId])
}

/// Phase 1 IPD bill (one-to-many per admission: interim / final / supplementary).
/// Charges are frozen line items (IpdCharge); a FINAL bill is immutable.
model Bill {
  id             String    @id @default(cuid())
  organizationId String
  admissionId    String // NOT unique — many bills per admission
  billNumber     String? // assigned only at finalize
  status         String    @default("DRAFT") // DRAFT | FINAL | CANCELLED
  billType       String    @default("FINAL") // INTERIM | FINAL | SUPPLEMENTARY
  payerType      String    @default("CASH") // CASH | INSURANCE | TPA | CORPORATE | GOVT | EMPLOYEE

  bedTotal      Float @default(0)
  serviceTotal  Float @default(0)
  subtotal      Float @default(0)
  taxTotal      Float @default(0)
  discountTotal Float @default(0)
  depositTotal  Float @default(0)
  payableTotal  Float @default(0)

  // Phase 2: payment rollup (ledger = source of truth; these are a cache)
  paidTotal     Float  @default(0)
  balanceDue    Float  @default(0)
  paymentStatus String @default("UNPAID") // UNPAID | PARTIAL | PAID | REFUNDED

  cancelReason String?
  finalizedAt  DateTime?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission    Admission     @relation(fields: [admissionId], references: [id], onDelete: Restrict)
  charges      IpdCharge[]
  payments     BillPayment[]

  @@unique([organizationId, billNumber])
  @@index([organizationId, status])
  @@index([admissionId])
}

/// Phase 2: IPD payment ledger — signed, immutable, numbered receipts.
/// ADVANCE/PAYMENT = +amount, REFUND = −amount. Cancelling a bill detaches
/// (billId=null) its payments; they re-link to the replacement on bill-generate.
model BillPayment {
  id             String   @id @default(cuid())
  organizationId String
  billId         String?
  admissionId    String
  receiptNumber  String? // RCP-<FY>-NNNNNN, on SUCCESS only
  type           String   @default("PAYMENT") // ADVANCE | PAYMENT | REFUND
  amount         Float // + advance/payment, − refund
  method         String // CASH | UPI | CARD | BANK_TRANSFER | CHEQUE
  reference      String? // UTR / txn / cheque no / 'legacy-deposit'
  status         String   @default("SUCCESS") // SUCCESS | VOID
  voidReason     String?
  note           String?
  creditNoteId   String? // future (Phase 3)
  idempotencyKey String?
  receivedById   String?
  receivedByName String?
  paidAt         DateTime @default(now())
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bill         Bill?        @relation(fields: [billId], references: [id], onDelete: SetNull)
  admission    Admission    @relation(fields: [admissionId], references: [id], onDelete: Restrict)

  @@unique([organizationId, receiptNumber])
  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, billId])
  @@index([organizationId, paidAt])
  @@index([admissionId])
}

/// Per-organization, per-financial-year bill number sequence (atomic increment).
model BillCounter {
  id             String @id @default(cuid())
  organizationId String
  series         String // "IPD"
  year           String // financial year e.g. "2026-27"
  value          Int    @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, series, year])
}

// ── Phase 2: Nursing Station — vitals, structured notes, eMAR ─────────────────

/// Time-series vitals with NEWS2 early-warning score
model VitalsRecord {
  id              String   @id @default(cuid())
  organizationId  String
  admissionId     String
  recordedAt      DateTime @default(now())
  systolicBp      Int?
  diastolicBp     Int?
  heartRate       Int?
  respiratoryRate Int?
  spo2            Float?
  tempC           Float?
  painScore       Int? // 0-10
  consciousness   String? // ALERT | CONFUSION | VOICE | PAIN | UNRESPONSIVE (AVPU)
  gcs             Int?
  intakeMl        Int?
  outputMl        Int?
  bloodSugar      Float?
  newsScore       Int? // computed
  newsRisk        String? // LOW | MEDIUM | HIGH
  recordedById    String?
  recordedByName  String?
  notes           String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission    Admission    @relation(fields: [admissionId], references: [id], onDelete: Restrict)

  @@index([organizationId, admissionId, recordedAt])
}

/// Append-only clinical/nursing notes (replaces JSON blob on Admission)
model ClinicalNote {
  id             String   @id @default(cuid())
  organizationId String
  admissionId    String
  noteType       String // Nursing admission assessment | Shift handover note | Other notes
  body           String
  authorId       String?
  authorName     String?
  authoredAt     DateTime @default(now())
  parentId       String? // addendum chain — corrections never overwrite
  vitals         Json? // optional snapshot

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission    Admission    @relation(fields: [admissionId], references: [id], onDelete: Restrict)

  @@index([organizationId, admissionId, authoredAt])
}

/// eMAR — bedside medication administration (links loosely to JSON-item Prescription)
model MedicationAdministration {
  id             String    @id @default(cuid())
  organizationId String
  admissionId    String
  prescriptionId String? // Prescription stores items as JSON, so this is a soft link
  drugName       String
  dosage         String?
  route          String?
  scheduledAt    DateTime?
  administeredAt DateTime?
  status         String // GIVEN | MISSED | HELD | REFUSED | DUE
  reason         String?
  nurseId        String?
  nurseName      String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission    Admission    @relation(fields: [admissionId], references: [id], onDelete: Restrict)

  @@index([organizationId, admissionId, scheduledAt])
}

// ── Phase 3: Discharge clearances, bed turnover ───────────────────────────────

/// Multi-disciplinary discharge clearance gate (one row per department per admission)
model DischargeClearance {
  id             String    @id @default(cuid())
  organizationId String
  admissionId    String
  type           String // DOCTOR | NURSING | PHARMACY | BILLING | HOUSEKEEPING
  status         String    @default("PENDING") // PENDING | CLEARED | BLOCKED
  clearedById    String?
  clearedByName  String?
  clearedAt      DateTime?
  remark         String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission    Admission    @relation(fields: [admissionId], references: [id], onDelete: Restrict)

  @@unique([admissionId, type])
  @@index([organizationId, admissionId])
}

/// Bed turnover / housekeeping task (drives OCCUPIED → DIRTY → CLEANING → AVAILABLE)
model HousekeepingTask {
  id             String    @id @default(cuid())
  organizationId String
  bedId          String
  admissionId    String?
  type           String    @default("CLEANING") // CLEANING | FUMIGATION | INSPECTION
  status         String    @default("OPEN") // OPEN | IN_PROGRESS | DONE
  assignedToName String?
  notes          String?
  openedAt       DateTime  @default(now())
  closedAt       DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bed          Bed          @relation(fields: [bedId], references: [id])

  @@index([organizationId, status])
  @@index([bedId])
}

// ── Phase 3A: Clinical Orders (CPOE) spine ────────────────────────────────────
// SPINE ONLY in 3A: doctors place type-bound orders that move through a canonical
// lifecycle with full audit. NO executor dispatch and NO auto-billing in 3A —
// executorModel/executorId/billed/ipdChargeId are reserved for 3B+ (Procedure→
// Lab→Radiology→Pharmacy). Billing stays manual via post-charge.

/// CPOE order spine — one billable clinical intent per admission.
model ClinicalOrder {
  id             String @id @default(cuid())
  organizationId String
  admissionId    String
  patientId      String

  orderType    String // LAB | RADIOLOGY | PHARMACY | PROCEDURE
  catalogModel String? // LabTest | RadiologyExam | PharmacyDrug | ChargeMaster
  catalogItemId String?
  itemName     String // snapshot (survives catalog edits)
  itemCode     String?
  serviceGroup String // LAB | RADIOLOGY | PHARMACY | PROCEDURE

  priority           String  @default("ROUTINE") // ROUTINE | URGENT | STAT
  quantity           Float   @default(1)
  frequency          String?
  dosage             String?
  route              String?
  duration           String?
  clinicalIndication String?
  notes              String?

  status       String  @default("ORDERED") // ORDERED|ACKNOWLEDGED|IN_PROGRESS|COMPLETED|CANCELLED
  domainStatus String? // reserved (3B+)

  orderedById      String?
  orderedByName    String?
  orderedAt        DateTime  @default(now())
  acknowledgedById String?
  acknowledgedByName String?
  acknowledgedAt   DateTime?
  startedById      String?
  startedByName    String?
  startedAt        DateTime?
  completedById    String?
  completedByName  String?
  completedAt      DateTime?
  cancelledById    String?
  cancelledByName  String?
  cancelledAt      DateTime?
  cancelReason     String?

  executorModel String? // reserved (3B+)
  executorId    String? // reserved (3B+)
  billed        Boolean @default(false) // reserved (3B+)
  ipdChargeId   String? // reserved (3B+)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission    Admission            @relation(fields: [admissionId], references: [id], onDelete: Restrict)
  events       ClinicalOrderEvent[]
  tasks        OrderTask[]

  @@index([organizationId, admissionId, status])
  @@index([organizationId, orderType, status])
  @@index([admissionId])
}

/// One scheduled occurrence of a repeating order (e.g. ABG TDS x2d → 6 rows).
/// Generated from ClinicalOrder.frequency + duration; the nurse ticks each one.
model OrderTask {
  id             String   @id @default(cuid())
  organizationId String
  admissionId    String
  orderId        String

  orderType   String // LAB | RADIOLOGY | PHARMACY | PROCEDURE (snapshot)
  itemName    String // snapshot of test/drug name (survives order edits)
  scheduledAt DateTime // exact date+time this occurrence is due

  status      String    @default("DUE") // DUE | DONE | MISSED | HELD | SKIPPED
  doneAt      DateTime?
  doneById    String?
  doneByName  String?
  resultValue String? // optional reading / observation captured at the bedside
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission    Admission     @relation(fields: [admissionId], references: [id], onDelete: Restrict)
  order        ClinicalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([organizationId, admissionId, scheduledAt])
  @@index([orderId])
}

/// Append-only lifecycle timeline for an order (UI timeline; complements AuditLog).
model ClinicalOrderEvent {
  id             String   @id @default(cuid())
  organizationId String
  orderId        String
  fromStatus     String?
  toStatus       String
  actorId        String?
  actorName      String?
  actorRole      String?
  remark         String?
  at             DateTime @default(now())

  order ClinicalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, at])
}

