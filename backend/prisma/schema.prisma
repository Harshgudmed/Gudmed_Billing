// ============================================
// IPD SPECIALIST CONSULTATION
// ============================================

/// IPD Specialist Consultation — called during inpatient stay.
/// Links an Admission to any external-department doctor (Eye, ENT, Ortho, Medicine…).
/// On status → COMPLETED the service auto-posts one IpdCharge (per-visit, room-adjusted)
/// and one DoctorCommission row using the consulting doctor's DoctorCommissionConfig.
model IpdConsultation {
  id             String   @id @default(cuid())
  organizationId String

  admissionId        String
  consultingDoctorId String
  requestedById      String?
  departmentId       String?


  // Scheduling
  requestedAt  DateTime  @default(now())
  scheduledAt  DateTime?
  completedAt  DateTime?

  // Status lifecycle: REQUESTED | IN_PROGRESS | COMPLETED | BILLED | CANCELLED
  status       String    @default("REQUESTED")

  // Clinical output (filled by consulting doctor)
  referralReason     String?
  consultationNotes  String?
  diagnosis          String?
  recommendedPlan    String?
  followUpRequired   Boolean  @default(false)
  followUpNotes      String?

  // Billing linkage — set automatically when status → COMPLETED
  ipdChargeId      String?  @unique   // one charge per consultation (SetNull on charge cancel)
  feeApplied       Float?             // snapshot of fee charged
  commissionAmount Float?             // snapshot of commission earned

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ────────────────────────────────────────────────────────────────
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  admission        Admission     @relation(fields: [admissionId], references: [id], onDelete: Restrict)
  consultingDoctor User          @relation("ConsultingDoctorIPD", fields: [consultingDoctorId], references: [id])
  requestedBy      User?         @relation("ConsultationRequestedBy", fields: [requestedById], references: [id])
  department       Department?   @relation(fields: [departmentId], references: [id])
  ipdCharge        IpdCharge?    @relation(fields: [ipdChargeId], references: [id], onDelete: SetNull)

  @@index([organizationId, admissionId])
  @@index([consultingDoctorId])
  @@index([status])
}

// ============================================
// LABORATORY (catalog + orders used by Consultations; standalone page removed)
// ============================================

/// Lab Test (Test Catalog)
model LabTest {
  id                      String @id @default(cuid())
  organizationId          String
  testName                String
  testCode                String?
  testCategory            String?
  testType                String?
  specimenType            String?
  specimenVolume          String?
  specimenContainer       String?
  resultType              String?
  unit                    String?
  referenceRanges         String?
  price                   Float?
  turnaroundTime          Int?
  department              String?
  preparationInstructions String?
  clinicalSignificance    String?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  createdById             String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  results      LabResult[]

  @@index([organizationId])
  @@index([testCategory])
}

/// Lab Order
model LabOrder {
  id                   String   @id @default(cuid())
  organizationId       String
  patientId            String
  consultationId       String?
  requestedById        String
  orderDate            DateTime @default(now())
  orderNumber          String   @unique
  tests                String
  clinicalIndication   String?
  provisionalDiagnosis String?
  priority             String   @default("routine")
  status               String   @default("pending")
  sampleCollectedAt    DateTime?
  sampleCollectedById  String?
  accessionNumber      String?  @unique
  resultsEnteredAt     DateTime?
  resultsEnteredById   String?
  resultsVerifiedAt    DateTime?
  resultsVerifiedById  String?
  resultsReportedAt    DateTime?
  notes                String?
  rejectionReason      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  createdById          String?

  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient           Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultation      Consultation? @relation(fields: [consultationId], references: [id])
  requestedBy       User          @relation("LabOrdersRequested", fields: [requestedById], references: [id])
  sampleCollectedBy User?         @relation("LabOrdersCollected", fields: [sampleCollectedById], references: [id])
  results           LabResult[]

  @@index([accessionNumber])
  @@index([organizationId])
  @@index([patientId])
  @@index([status])
}

/// Lab Result
model LabResult {
  id                 String   @id @default(cuid())
  organizationId     String?
  orderId            String
  testId             String
  resultValue        String
  resultUnit         String?
  isAbnormal         Boolean  @default(false)
  isCritical         Boolean  @default(false)
  flag               String?
  referenceRangeMin  Float?
  referenceRangeMax  Float?
  referenceRangeText String?
  qcLevel            String?
  qcPassed           Boolean?
  methodUsed         String?
  instrumentUsed     String?
  enteredById        String?
  enteredAt          DateTime  @default(now())
  verifiedById       String?
  verifiedAt         DateTime?
  comment            String?
  technicianNotes    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  order      LabOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  test       LabTest  @relation(fields: [testId], references: [id])
  enteredBy  User?    @relation("LabResultsEntered", fields: [enteredById], references: [id])
  verifiedBy User?    @relation("LabResultsVerified", fields: [verifiedById], references: [id])

  @@index([isCritical])
  @@index([orderId])
}

// ============================================
// RADIOLOGY (catalog + orders used by Consultations; standalone page removed)
// ============================================

/// Radiology Exam (Exam Catalog)
model RadiologyExam {
  id             String @id @default(cuid())
  organizationId String

  examName     String
  examCode     String?
  examCategory String?
  bodyPart     String?
  modality     String?
  price        Float?
  estimatedDuration Int?
  preparationInstructions String?
  contrastRequired        Boolean @default(false)
  description String?
  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  radiologyOrders RadiologyOrder[]

  @@index([organizationId])
  @@index([examCategory])
}

/// Radiology Order
model RadiologyOrder {
  id             String @id @default(cuid())
  organizationId String

  patientId      String
  consultationId String?
  requestedById  String
  examId         String

  orderDate   DateTime @default(now())
  orderNumber String   @unique

  clinicalIndication   String?
  provisionalDiagnosis String?
  relevantHistory      String?
  urgency String @default("routine")
  status String @default("pending")
  scheduledDate DateTime?
  examPerformedAt DateTime?
  performedById   String?
  reportCreatedAt  DateTime?
  reportedById     String?
  reportVerifiedAt DateTime?
  verifiedById     String?
  notes              String?
  cancellationReason String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultation Consultation?    @relation(fields: [consultationId], references: [id])
  requestedBy  User             @relation("RadiologyOrdersRequested", fields: [requestedById], references: [id])
  performedBy  User?            @relation("RadiologyOrdersPerformed", fields: [performedById], references: [id])
  exam         RadiologyExam    @relation(fields: [examId], references: [id])
  report       RadiologyReport?

  @@index([organizationId])
  @@index([patientId])
  @@index([status])
}

/// Radiology Report
model RadiologyReport {
  id             String  @id @default(cuid())
  organizationId String?

  orderId String @unique

  technique       String?
  findings        String?
  impression      String?
  recommendations String?
  hasCriticalFindings Boolean   @default(false)
  criticalFindings    String?
  criticalNotifiedTo  String?
  criticalNotifiedAt  DateTime?
  comparedWithPrevious Boolean @default(false)
  comparisonNotes      String?
  images        String?
  dicomStudyUid String?
  templateUsed String?
  reportedById String?
  reportedAt   DateTime  @default(now())
  verifiedById String?
  verifiedAt   DateTime?
  status          String    @default("draft")
  amendmentReason String?
  amendedAt       DateTime?
  amendedById     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order      RadiologyOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reportedBy User?          @relation("RadiologyReports", fields: [reportedById], references: [id])

  @@index([hasCriticalFindings])
}
