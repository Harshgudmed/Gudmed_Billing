/// Billing Service (Service Catalog)
model BillingService {
  id             String @id @default(cuid())
  organizationId String

  // Service Information
  serviceName     String
  serviceCode     String?
  serviceCategory String? // consultation, procedure, accommodation
  department      String?

  // Pricing
  unitPrice Float

  // Tax
  isTaxable     Boolean @default(false)
  taxPercentage Float   @default(0)

  // Insurance
  isCoveredByInsurance     Boolean @default(true)
  insuranceCopayPercentage Float?

  // Additional
  description String?
  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([serviceCategory])
}

/// Invoice
model Invoice {
  id             String @id @default(cuid())
  organizationId String

  // Relations
  patientId      String
  consultationId String?

  // Invoice Details
  invoiceNumber String    @unique
  invoiceDate   DateTime  @default(now())
  dueDate       DateTime?

  // Items (JSON array)
  items String // JSON: [{type, referenceId, description, quantity, unitPrice, discount, tax, total}]

  // Financial Summary
  subtotal           Float
  discountAmount     Float @default(0)
  discountPercentage Float @default(0)
  taxAmount          Float @default(0)
  totalAmount        Float

  // Payment
  paymentStatus String @default("unpaid") // unpaid, partially_paid, paid, cancelled, refunded
  amountPaid    Float  @default(0)
  balanceDue    Float?

  // Insurance
  insuranceClaimAmount Float   @default(0)
  insuranceClaimStatus String?
  patientCopayAmount   Float   @default(0)

  // Status
  status String @default("draft") // draft, sent, overdue, paid, cancelled

  // Notes
  notes              String?
  termsAndConditions String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdById        String?
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultation Consultation? @relation(fields: [consultationId], references: [id])
  createdBy    User?         @relation("InvoicesCreated", fields: [createdById], references: [id])
  cancelledBy  User?         @relation("InvoicesCancelled", fields: [cancelledById], references: [id])
  payments     Payment[]

  @@index([organizationId])
  @@index([patientId])
  @@index([invoiceNumber])
  @@index([paymentStatus])
}

/// Payment
model Payment {
  id             String @id @default(cuid())
  organizationId String

  // Relations
  invoiceId String
  patientId String?

  // Payment Details
  paymentDate   DateTime @default(now())
  receiptNumber String   @unique
  amount        Float

  // Payment Method
  paymentMethod String // cash, credit_card, debit_card, mobile_money, insurance, bank_transfer, cheque

  // Method-specific Details
  paymentReference    String? // transaction ID, cheque number
  cardLastFour        String?
  mobileMoneyProvider String? // UPI, Paytm, PhonePe

  // Bank Details
  bankName     String?
  chequeNumber String?
  chequeDate   DateTime?

  // Processing
  processedById String?

  // Refund
  isRefund          Boolean @default(false)
  refundReason      String?
  originalPaymentId String?

  // Notes
  notes String?

  createdAt   DateTime @default(now())
  createdById String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  patient      Patient?     @relation(fields: [patientId], references: [id])
  processedBy  User?        @relation("PaymentsProcessed", fields: [processedById], references: [id])

  @@index([organizationId])
  @@index([invoiceId])
  @@index([patientId])
  @@index([receiptNumber])
}

/// Doctor Fee Slab (day-based follow-up fee structure)
model DoctorFeeSlab {
  id             String  @id @default(cuid())
  organizationId String
  doctorId       String

  // Slab definition: applies fee when days_since_last_visit is in range [fromDays, toDays)
  fromDays       Int
  toDays         Int
  feeAmount      Float

  // Status and notes
  isActive       Boolean @default(true)
  notes          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  doctor         User         @relation("DoctorFeeSlabs", fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, fromDays, toDays])
  @@index([doctorId])
  @@index([organizationId])
}

/// Doctor Commission Configuration (rate per doctor)
model DoctorCommissionConfig {
  id             String  @id @default(cuid())
  organizationId String
  doctorId       String  @unique

  commissionType String  @default("percentage") // percentage | fixed_per_consultation
  commissionRate Float   @default(10)           // % or fixed ₹ amount
  isActive       Boolean @default(true)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  doctor       User         @relation("DoctorCommissionConfig", fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

/// Doctor Commission Record (one per invoice/consultation)
model DoctorCommission {
  id             String @id @default(cuid())
  organizationId String
  doctorId       String

  invoiceId      String?
  invoiceAmount  Float
  commissionRate Float
  commissionType String  @default("percentage")
  commissionAmount Float

  status         String  @default("pending")  // pending | approved | paid | cancelled
  period         String? // e.g. "2026-05" for monthly grouping

  settledAt      DateTime?
  settledById    String?
  settlementNote String?
  settlementRef  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  doctor       User         @relation("DoctorCommissions", fields: [doctorId], references: [id], onDelete: Cascade)
  settledBy    User?        @relation("CommissionsSettled", fields: [settledById], references: [id])

  @@index([organizationId])
  @@index([doctorId])
  @@index([status])
  @@index([period])
}

// ============================================
// INTEGRATION & SYSTEM TABLES
// ============================================

/// Machine Integration
model MachineIntegration {
  id             String @id @default(cuid())
  organizationId String

  // Machine Information
  machineName  String
  machineType  MachineType // lab_analyzer, radiology_equipment, vital_signs_monitor
  manufacturer String?
  model        String?
  serialNumber String?
  department   String? // laboratory, radiology, icu, emergency

  // Connection Configuration
  connectionType    ConnectionType // hl7, astm, rest_api, file_upload, serial
  connectionDetails String         @default("{}") // JSON: {ip_address, port, protocol_version, etc}

  // Test Mapping
  testMapping String @default("{}") // JSON: {machine_test_code: system_test_id}

  // Status
  isActive             Boolean          @default(true)
  connectionStatus     ConnectionStatus @default(disconnected)
  lastConnectedAt      DateTime?
  lastResultReceivedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resultsQueue    MachineResultsQueue[]
  integrationLogs IntegrationLog[]

  @@index([organizationId])
  @@index([machineType])
  @@index([connectionStatus])
}

/// Machine Results Queue (for automatic result import)
model MachineResultsQueue {
  id                   String @id @default(cuid())
  organizationId       String
  machineIntegrationId String

  // Raw Data
  rawData    String // HL7/ASTM message or JSON
  parsedData String? // JSON: parsed result data

  // Patient Identification
  patientIdentifier String? // from machine (MRN, name, etc)
  matchedPatientId  String? // after matching

  // Results
  testResults String @default("[]") // JSON array of test results

  // Processing Status
  status       QueueStatus @default(pending)
  errorMessage String?

  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  machineIntegration MachineIntegration @relation(fields: [machineIntegrationId], references: [id], onDelete: Cascade)
  patient            Patient?           @relation(fields: [matchedPatientId], references: [id])

  @@index([organizationId])
  @@index([machineIntegrationId])
  @@index([status])
  @@index([receivedAt])
}

/// Integration Log
model IntegrationLog {
  id                   String  @id @default(cuid())
  organizationId       String?
  machineIntegrationId String?

  // Log Details
  logDate DateTime @default(now())
  logType LogType? // connection, result_import, error, config_change
  message String
  details String? // JSON: additional details

  // Results Stats
  resultsImported Int @default(0)
  resultsFailed   Int @default(0)

  createdAt DateTime @default(now())

  machineIntegration MachineIntegration? @relation(fields: [machineIntegrationId], references: [id])

  @@index([machineIntegrationId])
  @@index([logDate])
  @@index([logType])
}

// Integration Enums
enum MachineType {
  lab_analyzer
  radiology_equipment
  vital_signs_monitor
}

enum ConnectionType {
  hl7
  astm
  rest_api
  file_upload
  serial
}

enum ConnectionStatus {
  connected
  disconnected
  error
}

enum QueueStatus {
  pending
  matched
  imported
  failed
  manual_review
}

enum LogType {
  connection
  result_import
  error
  config_change
}

// ============================================
// USER MANAGEMENT & PERMISSIONS
// ============================================

/// User Invitation
model UserInvitation {
  id             String   @id @default(cuid())
  organizationId String
  
  // Invitation Details
  email          String
  role           String
  departmentIds  String?  // JSON array of department IDs
  token          String   @unique
  expiresAt      DateTime
  
  // Status
  status         InvitationStatus @default(pending)
  acceptedAt     DateTime?
  
  // Metadata
  createdAt      DateTime @default(now())
  sentById       String
  
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sentBy         User         @relation("InvitationsSent", fields: [sentById], references: [id])
  
  @@index([organizationId])
  @@index([email])
  @@index([token])
  @@index([status])
}

/// Permission
model Permission {
  id          String   @id @default(cuid())
  
  // Permission Details
  code        String   @unique  // e.g., "patients:create"
  name        String              // e.g., "Create Patient"
  description String?
  category    String              // e.g., "patients", "lab", "pharmacy"
  
  createdAt   DateTime @default(now())
  
  rolePermissions RolePermission[]
  
  @@index([category])
  @@index([code])
}

/// Role Permission Mapping
model RolePermission {
  id           String @id @default(cuid())
  
  role         String       // matches User.role
  permissionId String
  
  // Optional: granular control
  canCreate    Boolean @default(false)
  canRead      Boolean @default(false)
  canUpdate    Boolean @default(false)
  canDelete    Boolean @default(false)
  
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@unique([role, permissionId])
  @@index([role])
}

/// User Activity Log
model UserActivity {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String
  
  // Activity Details
  action         String   // login, logout, create_patient, update_prescription, etc.
  entityType     String?  // patient, prescription, lab_order, etc.
  entityId       String?
  details        String?  // JSON: additional context
  
  // Metadata
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime @default(now())
  
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

// User Management Enums
enum InvitationStatus {
  pending
  accepted
  expired
  cancelled
}

/// Audit Log
model AuditLog {
  id             String @id @default(cuid())
  organizationId String

  // User & Action
  userId    String?
  userEmail String?
  userRole  String?

  // Action Details
  action     String // create, update, delete, view, login, logout
  entityType String? // patient, prescription, invoice, etc.
  entityId   String?

  // Changes (JSON)
  oldValues String?
  newValues String?

  // Context
  ipAddress String?
  userAgent String?

  // Timestamp
  performedAt DateTime @default(now())

  // Additional
  description String?
  metadata    String? // JSON

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation("AuditLogsByUser", fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([performedAt])
}

/// Notification
model Notification {
  id             String @id @default(cuid())
  organizationId String

  // Recipient
  userId String

  // Notification Details
  notificationType String? // appointment_reminder, lab_result_ready, critical_result, low_stock
  title            String
  message          String

  // Related Entity
  entityType String?
  entityId   String?

  // Delivery
  deliveryMethod String? // in_app, email, sms, push
  isRead         Boolean   @default(false)
  readAt         DateTime?

  // Priority
  priority String @default("normal") // low, normal, high, urgent

  // Scheduled
  sendAt DateTime  @default(now())
  sentAt DateTime?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([notificationType])
}

