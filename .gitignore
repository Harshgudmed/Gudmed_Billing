# Dependencies (reinstalled via npm install — never commit)
node_modules/
backend/node_modules/

# Build output
dist/
build/

# Large reference PDFs — not part of the app
/Vol*.pdf

# Secrets / environment (contains real API keys — DO NOT commit)
.env
.env.*
backend/.env
backend/.env.*
!.env.example

# DB drift backup dumps (contain real patient/medical data — DO NOT commit)
backend/drift_tables_backup_*.json

# Uploaded files
backend/uploads/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Prisma local
backend/prisma/*.db

# One-off migration scripts that contain a DB connection string — keep out of git
backend/full-migrate.js
backend/restore-from-render.js
