{
  "name": "hospital-frontend",
  "version": "1.0.0",
  "description": "Hospital Management System - React 19 + Vite Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k -n api,web -c blue,green \"npm --prefix backend run dev\" \"vite\"",
    "dev:lan": "vite --mode lan --host",
    "tunnel": "cloudflared tunnel --url http://localhost:5173",
    "dev:tunnel": "concurrently -k -n vite,tunnel -c green,cyan \"vite\" \"cloudflared tunnel --url http://localhost:5173\"",
    "dev:full": "concurrently -k -n api,web,tunnel -c blue,green,cyan \"npm --prefix backend run dev\" \"vite\" \"cloudflared tunnel --url http://localhost:5173\"",
    "build": "vite build",
    "preview": "vite preview",
    "size-check": "node backend/scripts/storage-report.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.2.4",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.511.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^6.30.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5"
  }
}
